parameters:
    level: 6
    paths:
        - src
    bootstrapFiles:
        - phpstan-bootstrap.php
    ignoreErrors:
        - identifier: missingType.iterableValue

    symfony:
        containerXmlPath: var/cache/test/CombatUI_Bundle_CoreBundle_Tests_Kernel_KernelTestDebugContainer.xml

includes:
    - vendor/phpstan/phpstan-symfony/extension.neon