{#
Case-study card (.cui-case-card) — edge-to-edge media over a stacked body.
Props: title, title_tag (default h3), href, meta (kicker, .cui-case-card-meta),
image, image_alt, variant (flat), id, class, attr.
Slots: default (body copy), media (replaces the image).
#}
{% set title_tag = props.title_tag|default('h3') %}
<article{{ cui_attrs({
    id: props.id|default(null),
    class: ['cui-surface', 'cui-case-card', props.class|default(null)],
    'data-variant': props.variant|default(null),
}|merge(props.attr|default({}))) }}>
    {% if slots.media is defined %}
        {{ slots.media|raw }}
    {% elseif props.image is defined %}
        <img class="cui-case-card-media" src="{{ props.image }}" alt="{{ props.image_alt|default('') }}">
    {% endif %}
    <div class="cui-case-card-body cui-stack">
        {% if props.meta is defined %}<p class="cui-case-card-meta">{{ props.meta }}</p>{% endif %}
        {% if props.title is defined %}
            <{{ title_tag }}>
                {%- if props.href is defined %}<a href="{{ props.href }}">{{ props.title }}</a>{% else %}{{ props.title }}{% endif -%}
            </{{ title_tag }}>
        {% endif %}
        {{ slots.default|default('')|raw }}
    </div>
</article>
