{#
    Generic renderer for any Combat UI custom element that has no curated template. Context tag (string), attrs (hash),
    named_slots (ordered list of {name, content} — one entry per `{% cui_slot %}`, so repeated slot names stay
    distinct light-DOM children), slots.default (the tag body).
#}
<{{ tag }}{{ cui_attrs(attrs|default({})) }}>
    {%- for slot in named_slots|default([]) -%}
        <div slot="{{ slot.name }}">{{ slot.content|raw }}</div>
    {%- endfor -%}
    {{- slots.default|default('')|raw -}}
</{{ tag }}>
