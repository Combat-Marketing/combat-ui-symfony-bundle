{#
Overlay card (.cui-media-overlay) — copy layered over a media background
with a configurable scrim. Note: no .cui-surface here by design.
Props: title, title_tag (default h3), eyebrow, image, image_alt,
align (center|end — default bottom-start), scrim (solid|top|none — default
bottom-up gradient), ratio (square|portrait|wide|auto), radius ('none'),
id, class, attr.
Slots: default (copy below the title), media (custom media markup), actions.
#}
{% set title_tag = props.title_tag|default('h3') %}
<article{{ cui_attrs({
    id: props.id|default(null),
    class: ['cui-media-overlay', props.class|default(null)],
    'data-align': props.align|default(null),
    'data-scrim': props.scrim|default(null),
    'data-ratio': props.ratio|default(null),
    'data-radius': props.radius|default(null),
}|merge(props.attr|default({}))) }}>
    {% if slots.media is defined %}
        <div class="cui-media-overlay-media">{{ slots.media|raw }}</div>
    {% elseif props.image is defined %}
        <img src="{{ props.image }}" alt="{{ props.image_alt|default('') }}">
    {% endif %}
    <div class="cui-stack">
        {% if props.eyebrow is defined %}<p class="cui-eyebrow">{{ props.eyebrow }}</p>{% endif %}
        {% if props.title is defined %}<{{ title_tag }} class="cui-display">{{ props.title }}</{{ title_tag }}>{% endif %}
        {{ slots.default|default('')|raw }}
        {% if slots.actions is defined %}
            <div class="cui-cluster">{{ slots.actions|raw }}</div>
        {% endif %}
    </div>
</article>
