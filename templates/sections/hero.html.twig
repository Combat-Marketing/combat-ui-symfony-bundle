{#
Hero band (.cui-hero).
Props: variant (split|background|overlay|text — defaults to split when a
media slot is present, text otherwise), align (center), width
(narrow|default|wide), media_position (start), eyebrow, title, title_tag
(default h1), lead, background_image, background_position, id, class, attr.
Slots: default (extra content in the copy column), actions, media,
background (custom .cui-hero-bg markup).
#}
{% set variant = props.variant|default(slots.media is defined ? 'split' : 'text') %}
{% set title_tag = props.title_tag|default('h1') %}
<section{{ cui_attrs({
    id: props.id|default(null),
    class: ['cui-hero', props.class|default(null)],
    'data-variant': variant,
    'data-align': props.align|default(null),
    'data-width': props.width|default(null),
    'data-media': props.media_position|default(null),
}|merge(props.attr|default({}))) }}>
    {% if slots.background is defined %}
        {{ slots.background|raw }}
    {% elseif props.background_image is defined %}
        <div class="cui-hero-bg"{{ cui_attrs({style: {
            '--cui-hero-background-image': 'url(\'' ~ props.background_image ~ '\')',
            '--cui-hero-background-position': props.background_position|default(null),
        }}) }}></div>
    {% endif %}
    <div class="cui-hero-inner">
        <div class="cui-stack">
            {% if props.eyebrow is defined %}
                <p class="cui-eyebrow">{{ props.eyebrow }}</p>
            {% endif %}
            {% if props.title is defined %}
                <{{ title_tag }} class="cui-display">{{ props.title }}</{{ title_tag }}>
            {% endif %}
            {% if props.lead is defined %}
                <p>{{ props.lead }}</p>
            {% endif %}
            {{ slots.default|default('')|raw }}
            {% if slots.actions is defined %}
                <div class="cui-cluster">{{ slots.actions|raw }}</div>
            {% endif %}
        </div>
        {% if slots.media is defined %}
            <div class="cui-hero-media">{{ slots.media|raw }}</div>
        {% endif %}
    </div>
</section>