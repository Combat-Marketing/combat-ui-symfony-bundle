{#
Call-to-action block (.cui-cta).
Props: variant (simple|split|full-bleed|sticky), tone (inverse), eyebrow,
title, title_tag (default h2), lead, id, class, attr.
Slots: default (extra content in the copy column), actions.
#}
{%- set title_tag = props.title_tag|default('h2') -%}
<section{{ cui_attrs({
    id: props.id|default(null),
    class: ['cui-cta', 'cui-surface', 'cui-stack', props.class|default(null)],
    'data-variant': props.variant|default('simple'),
    'data-tone': props.tone|default(null),
}|merge(props.attr|default({}))) }}>
    <div class="cui-cta-content cui-stack">
        {% if props.eyebrow is defined %}<p class="cui-eyebrow">{{ props.eyebrow }}</p>{% endif %}
        {% if props.title is defined %}<{{ title_tag }} class="cui-cta-title">{{ props.title }}</{{ title_tag }}>{% endif %}
        {% if props.lead is defined %}<p>{{ props.lead }}</p>{% endif %}
        {{ slots.default|default('')|raw }}
    </div>
    {% if slots.actions is defined %}
        <div class="cui-cluster">{{ slots.actions|raw }}</div>
    {% endif %}
</section>